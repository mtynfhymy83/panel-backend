# ---- App ----
APP_HOST=0.0.0.0
APP_PORT=9501
APP_DEBUG=1

# Comma-separated origins allowed in production (when APP_DEBUG=0)
# CORS_ALLOWED_ORIGINS=https://panel.pardis-book.ir,http://localhost:3000

# ---- Swoole ----
SWOOLE_WORKER_NUM=4
SWOOLE_ENABLE_CURL_HOOK=false
SWOOLE_HTTP_COMPRESSION=true

# Cache instances of controllers per worker (true = faster, false = fresh each request)
CONTROLLER_CACHE=true

# ---- Auth (JWT) ----
JWT_SECRET=REPLACE_WITH_AT_LEAST_32_RANDOM_BYTES
JWT_ALGO=HS256
JWT_TTL=60

# ---- Cache (file | redis) ----
CACHE_DRIVER=file
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_DB=0

# ---- Default admin (run: php scripts/seed.php) ----
ADMIN_FIRST_NAME=System
ADMIN_LAST_NAME=Admin
ADMIN_PASSWORD=change-me-in-production
ADMIN_PHONE=09120000001
ADMIN_EMAIL=admin@example.com

# ---- Database ----
# Required in production (APP_DEBUG=0). Without DB_DSN the server will not start.
#
# SQLite (local only):
# DB_DSN=sqlite:storage/app.db
#
# PostgreSQL (production example):
# DB_DSN=pgsql:host=45.156.186.63;port=23695;dbname=your_db_name
# DB_USERNAME=your_user
# DB_PASSWORD=your_password
#
# MySQL:
# DB_DSN=mysql:host=127.0.0.1;port=3306;dbname=app;charset=utf8mb4
# DB_USERNAME=root
# DB_PASSWORD=secret

DB_DSN=sqlite:storage/app.db
DB_USERNAME=
DB_PASSWORD=
DB_POOL_SIZE=10

# Pool tuning (optional)
# DB_MAX_IDLE_TIME=600
# DB_POOL_POP_TIMEOUT_SECONDS=1.0
# DB_POOL_LEAK_DETECTION_ENABLED=1
# DB_POOL_LEAK_THRESHOLD_MS=15000

# ---- SMS (fake | smsir) ----
SMS_DRIVER=fake
SMS_IR_API_KEY=
SMS_IR_TEMPLATE_ID=
SMS_IR_OTP_PARAMETER=CODE

# ---- OTP delivery (sms | email | both) ----
OTP_CHANNEL=sms
# Dev/testing only: include debugOtp in OTP responses.
OTP_DEBUG_RESPONSE=0

# ---- Mail (log | smtp) — used when OTP_CHANNEL=email or both ----
MAIL_DRIVER=log
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_ENCRYPTION=tls
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=
MAIL_FROM_NAME=Pardis Panel
