{
  "name": "skeleton/swoole-clean-api",
  "description": "Swoole REST API skeleton with Clean Architecture / DDD",
  "type": "project",
  "license": "MIT",
  "autoload": {
    "psr-4": {
      "App\\": "App/"
    },
    "files": [
      "App/Helpers/Helper.php"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "require": {
    "php": ">=8.1",
    "vlucas/phpdotenv": "^5.4",
    "php-di/php-di": "^7.0",
    "firebase/php-jwt": "^6.10",
    "predis/predis": "2.2"
  },
  "require-dev": {
    "phpunit/phpunit": "^9.5",
    "phpstan/phpstan": "^1.12"
  },
  "scripts": {
    "start": "php server.php",
    "test": "phpunit",
    "analyse": "phpstan analyse --memory-limit=1G"
  }
}
